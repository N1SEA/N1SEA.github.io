generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Skill {
  id    Int     @id @default(autoincrement())
  name  String
  icon  String
  level Int
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  tech        String[] 
  link        String?
  github      String?
}